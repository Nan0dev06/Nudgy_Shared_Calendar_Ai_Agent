# Google OAuth 2.0 credentials (Google Cloud Console -> APIs & Services -> Credentials)
# Create an OAuth client of type "Web application" and add BOTH redirect URIs:
#   http://localhost:8765/            (Phase 1 CLI scripts)
#   http://localhost:8000/auth/google/callback   (Phase 2 web app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Phase 2+ (not needed for the Phase 1 CLI proof) ---
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- LLM provider for the Nudgy agent ---
# Default is Groq (free tier, fast). Options: groq | ollama | openai
LLM_PROVIDER=groq

# Groq (free): get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Only needed for other providers:
# LLM_API_KEY=                # if LLM_PROVIDER=openai
# Groq's free limits are PER MODEL. An agent turn costs ~4K tokens per LLM call
# and needs 3-4 calls (~15K/turn), so the daily budget is what matters:
#   llama-3.1-8b-instant     -> 500K tokens/day  (the default; ~30-40 turns/day)
#   llama-3.3-70b-versatile  -> 100K tokens/day  (smarter at tools, but only
#                               ~6-8 turns/day before it rate-limits — swap in
#                               only if you have budget headroom)
NUDGY_MODEL=llama-3.1-8b-instant
# LLM_BASE_URL=               # override the provider endpoint (e.g. custom Ollama host)

# --- Free backup provider: Cerebras (no credit card) -------------------------
# Runs the SMART llama-3.3-70b with a much bigger free budget than Groq. If
# Groq's daily cap still bites, sign up at https://cloud.cerebras.ai (Google
# login), make a key, and uncomment these three lines:
# LLM_PROVIDER=openai         # any OpenAI-compatible provider uses this path
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_API_KEY=                # your Cerebras key
# NUDGY_MODEL=llama-3.3-70b   # smart model, no tiny-budget problem
